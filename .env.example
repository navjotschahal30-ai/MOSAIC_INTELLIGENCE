# ── Ampre VOW (MLS/TRREB data) ─────────────────────────────────────────────
VOW_API_KEY=

# ── CREA DDF (nationwide fallback for boards without VOW/Cornerstone approval) ──
# "Destination Credentials" from CREA — used as client_id/client_secret in an
# OAuth2 client_credentials request to identity.crea.ca. Active listings only;
# DDF carries no sold/closed data.
DDF_CLIENT_ID=
DDF_CLIENT_SECRET=

# ── Claude (Anthropic) ───────────────────────────────────────────────────────
CLAUDE_API_KEY=

# ── Lofty (live listing-detail links for "similar active listings") ──────────
# Same account/key as navjot-vern's LOFTY_API_KEY. Only used to resolve
# currently-active MLS#s to a real navjotchahal.ca listing-detail link — see
# core/lofty-listing-link.js for why this is never done for sold comps.
LOFTY_API_KEY=
AGENT_WEBSITE=navjotchahal.ca

# ── Database (Phase 2) ─────────────────────────────────────────────────────────
# Postgres connection string — Railway: Project → New → Database → PostgreSQL,
# then copy the DATABASE_URL it generates.
DATABASE_URL=

# ── Auth (Phase 2) ───────────────────────────────────────────────────────────
# Any long random string. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=
# Must decode to exactly 32 bytes. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
# CORS origin allowlist — comma-separated domains, or * for open access
CORS_ORIGINS=*
